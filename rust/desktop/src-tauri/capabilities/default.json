{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:app:allow-name",
    "core:app:allow-version"
  ],
  "local": true,
  "remote": {
    "urls": []
  }
}
