# Mock Mode Configuration for Netlify/Demo Deployment
# This file contains only non-sensitive mock configuration
VITE_USE_MOCKS=true

# Mock API endpoints (not real servers)
VITE_API_BASE_URL=https://mock-api.example.com
VITE_WS_URL=wss://mock-ws.example.com

# Mock SSO Configuration (not real SSO platform)
VITE_SSO_BASE_URL=https://mock-sso.example.com
VITE_SSO_ORG_SLUG=demo-org
VITE_SSO_SERVICE_SLUG=demo-service

# Desktop app flag (false for web deployment)
VITE_DESKTOP_APP=false