# Desktop App Configuration
# Backend port will be determined dynamically at runtime
# These values are only used as fallbacks if dynamic detection fails
VITE_API_BASE_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# SSO Configuration (required for authentication)
VITE_SSO_BASE_URL=http://localhost:3000
VITE_SSO_ORG_SLUG=ai-code-terminal
VITE_SSO_SERVICE_SLUG=terminal

# Desktop app flag for frontend logic
VITE_DESKTOP_APP=true